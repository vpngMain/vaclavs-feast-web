# Google Maps browser key (build-time — baked into JS bundle by Vite)
# Used for: Maps Embed iframe on /kontakt
# Set this in Vercel: Settings → Environment Variables → VITE_GOOGLE_MAPS_KEY
VITE_GOOGLE_MAPS_KEY="AIzaSyBmvJph4LmrbtW7skeczzpBIyb9WWzFKo4"

# Google Maps server-side key (runtime — never exposed to browser)
# Used for: Places API reviews fetch in reviews.functions.ts
# Needs: Places API (Legacy) enabled in Google Cloud Console
# Set this in Vercel: Settings → Environment Variables → GOOGLE_MAPS_API_KEY
GOOGLE_MAPS_API_KEY=""
